
# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Merge Agent Handler
MERGE_API_KEY=your-merge-api-key

# ── Routing mode ──────────────────────────────────────────────────────────────
# Controls how the agent resolves Registered User and Tool Pack per session.
#
# MERGE_USER_ROUTING_MODE
#   static  → all Gemini users share MERGE_REGISTERED_USER_ID (default, good for initial testing)
#   dynamic → each Gemini user is mapped to their own Registered User via their email address.
#             Requires Registered Users to be created with origin_user_id = user's email.
#
# MERGE_TOOL_PACK_ROUTING_MODE
#   static  → all sessions use MERGE_TOOL_PACK_ID (default)
#   dynamic → each user's Tool Pack is determined by their team custom grouping.
#             Requires MERGE_USER_ROUTING_MODE=dynamic.
#
# Valid combinations:
#   static  + static  → Phase 1 shared setup
#   dynamic + static  → per-user routing, single org-wide Tool Pack
#   dynamic + dynamic → per-user routing, team-based Tool Pack mapping

MERGE_USER_ROUTING_MODE=static
MERGE_TOOL_PACK_ROUTING_MODE=static

# ── Static registered user ────────────────────────────────────────────────────
# Required when MERGE_USER_ROUTING_MODE=static
MERGE_REGISTERED_USER_ID=your-shared-registered-user-id

# ── Static tool pack ──────────────────────────────────────────────────────────
# Required when MERGE_TOOL_PACK_ROUTING_MODE=static
MERGE_TOOL_PACK_ID=your-tool-pack-id

# ── Dynamic tool pack ─────────────────────────────────────────────────────────
# Required when MERGE_TOOL_PACK_ROUTING_MODE=dynamic
#
# MERGE_TEAM_GROUPING_KEY: the key used to read the team from a Registered User's
# custom_groupings object (e.g. custom_groupings["Team"] = "Engineering").
# Must match the key you set when creating Registered Users in Merge.
MERGE_TEAM_GROUPING_KEY=Team
#
# MERGE_TOOL_PACK_MAP_FILE: path to a JSON file mapping team names to Tool Pack UUIDs.
# Copy tool_pack_map.example.json to tool_pack_map.json and fill in your UUIDs.
# Must include a "default" key as the fallback for users with a missing or unmapped team.
MERGE_TOOL_PACK_MAP_FILE=./tool_pack_map.json

# ── Optional ──────────────────────────────────────────────────────────────────
ADK_MODEL=gemini-flash-latest
# MERGE_MCP_FORMAT=json
# AGENT_DISPLAY_NAME=Merge Agent Handler Assistant
